{
    "name": "Dont Read Theme - Dark",
    "type": "dark",
    "colors": {
        "editor.background": "#121212",
        "editor.foreground": "#bbbbbb",
        "editorLineNumber.foreground": "#444444",
        "editorLineNumber.activeForeground": "#888888",
        "sideBar.background": "#0F0F0F",
        "sideBar.foreground": "#bbbbbb",
        "statusBar.background": "#0F0F0F",
        "statusBar.foreground": "#bbbbbb",
        "activityBar.background": "#0F0F0F",
        "activityBar.foreground": "#bbbbbb",
        "titleBar.activeBackground": "#0F0F0F",
        "titleBar.activeForeground": "#bbbbbb",
        "panel.background": "#121212",
        "panel.border": "#333333",
        "tab.activeBackground": "#121212",
        "tab.inactiveBackground": "#0F0F0F",
        "tab.activeForeground": "#ffffff",
        "tab.inactiveForeground": "#666666"
    },
    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "punctuation.definition.comment",
                "unused.comment"
            ],
            "settings": {
                "foreground": "#FF9100",
                "fontStyle": "bold italic"
            }
        },
        {
            "name": "Emphasized",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.namespace",
                "support.class",
                "storage.type.class",
                "storage.type.function",
                "storage.type.interface"
            ],
            "settings": {
                "foreground": "#dedede",
                "fontStyle": "bold"
            }
        },
        {
            "name": "Default",
            "scope": [
                "source",
                "text"
            ],
            "settings": {
                "foreground": "#bbbbbb",
                "fontStyle": ""
            }
        }
    ]
}